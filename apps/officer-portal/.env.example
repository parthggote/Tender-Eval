# Set these in Vercel dashboard → Project Settings → Environment Variables

# URL of this app (set to your Vercel deployment URL in production)
NEXT_PUBLIC_PORTAL_URL=https://your-app.vercel.app

# Render API service URL
NEXT_PUBLIC_INTERNAL_API_URL=https://tendereval-api.onrender.com

# Auth.js — must match AUTH_SECRET set on Render
AUTH_SECRET=changeme

# Required by NextAuth on Vercel — set to your deployment URL
NEXTAUTH_URL=https://your-app.vercel.app

# Supabase Postgres (for Auth.js / Prisma)
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
